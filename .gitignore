# ROS2 / colcon build artifacts - regenerated by `colcon build`, never commit
build/
install/
log/

# Python
__pycache__/
*.pyc
*.egg-info/

# Datasets - large, regenerable from the fetch/generate scripts, not code
dataset_merged/
coco_subset/
venue_photos/
*.zip

# Full training run outputs - large (validation batch images, caches, etc).
# We deliberately keep ONLY the small essentials via the models/ folder
# instead (see README) - don't commit the whole runs/ tree.
runs/

# Downloaded pretrained weights (auto re-downloaded by ultralytics on first
# run, no need to version these)
yolov8n.pt
yolov8s.pt

# Editor/OS cruft
.vscode/
.idea/
*.swp
.DS_Store
